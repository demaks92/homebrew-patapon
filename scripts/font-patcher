#!/usr/bin/env zsh
# -*- mode: sh; sh-indentation: 4; indent-tabs-mode: nil; sh-basic-offset: 4; -*-
# Plugin: macos
# Script: font-patcher
#
# Downloads the latest Nerd Fonts FontPatcher release, installs fontforge
# if missing, patches the given font files with complete glyph coverage
# (including nf-cod-copilot and nf-oct-copilot), and copies the result
# into ~/Library/Fonts.
#
# Usage:
#   font-patcher [options] <font-file> [font-file ...]
#   font-patcher [options] <directory>
#
# Options:
#   --ttf              Output as TrueType (default)
#   --otf              Output as OpenType
#   --mono             Patch as single-width / monospaced (default)
#   --no-mono          Patch as double-width / proportional
#   --out <dir>        Custom output directory (default: ~/Library/Fonts)
#   -h, --help         Show this help
#
# Examples:
#   font-patcher ~/fonts/MyFont-Regular.ttf
#   font-patcher --otf ~/fonts/*.ttf
#   font-patcher /path/to/nerd-fonts/src/unpatched-fonts/Meslo/S
#   font-patcher --out ./patched src/unpatched-fonts/Meslo/S/*/*.ttf

# If the function was called as a script
if [[ "$0" != font-patcher || -n "$ZSH_SCRIPT" ]]; then
    # Standardized $0 Handling
    # https://z.digitalclouds.dev/community/zsh_plugin_standard#zero-handling
    0="${ZERO:-${${0:#$ZSH_ARGZERO}:-${(%):-%N}}}"
    0="${${(M)${0::=${(%):-%x}}:#/*}:-$PWD/$0}"
    fpath+=( "$0:h" )
    if builtin autoload -Uz -- colors; then
        colors
    fi
fi

# Ensure consistent behavior and set recommended options
builtin emulate -L zsh
builtin setopt extended_glob warn_create_global typeset_silent no_short_loops rc_quotes no_prompt_subst no_auto_pushd err_exit

#################
### Constants ###
#################

typeset -r -a CORE_REQUIREMENTS=( curl mkdir mktemp unzip )
typeset -r -a FONT_EXTENSIONS=( ttf otf )
typeset -r DEFAULT_FONTS_DIR="${HOME}/Library/Fonts"
typeset -r NERD_FONTS_REPO="ryanoasis/nerd-fonts"
typeset -r GITHUB_API="https://api.github.com/repos/${NERD_FONTS_REPO}/releases/latest"

####################
### Core Helpers ###
####################

function .print-error() {

    builtin emulate -L zsh

    local date caller
    local -a message

    message=( "$@" )
    date="$(date '+%Y-%m-%d %H:%M:%S')"

    # The command '.print-error'' was called as a standalone script rather than as a function
    if (( ! ${#funcstack[@]} )); then
        caller=${"$(command ps -o args= -p $PPID | command sed 's/^[[:space:]]*//')"/zsh[[:space:]]/}
    # The file witch command '.print-error' was sourced
    elif [[ ${funcstack[1]} == */* ]]; then
        caller="${funcfiletrace[1]}"
    # The command '.print-error'' was called as a non-interactive function rather than as standalone script
    elif [[ ${funcstack[1]} != ${ZSH_SCRIPT:-$ZSH_ARGZERO} ]]; then
        caller="${funcfiletrace[1]}"
    # The command '.print-error'' was called as an interactive function rather than as standalone script
    elif [[ -n ${ZLAST_COMMANDS[1]} ]]; then
         caller="${ZLAST_COMMANDS[1]}"
    fi

    # We trim the $caller value, leaving only the file basename
    caller="${${caller:=$ZSH_ARGZERO}:t}"

    >&2 echo "$date ${caller:+(${fg[red]}${caller}${fg[default]})} [${fg[red]}error${fg[default]}]: ${message[@]}"
}

